<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wireless.mapper.ChatMessageMapper">

    <resultMap id="BaseResultMap" type="com.wireless.model.entity.ChatMessage">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="user_id" property="userId"/>
        <result column="model_id" property="modelId"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="action_result" property="actionResult"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message (session_id, user_id, model_id, role, content, action_result)
        VALUES (#{sessionId}, #{userId}, #{modelId}, #{role}, #{content}, #{actionResult})
    </insert>

    <select id="selectBySession" resultMap="BaseResultMap">
        SELECT * FROM chat_message
        WHERE session_id=#{sessionId}
        ORDER BY create_time ASC
        <if test="limit != null">LIMIT #{limit}</if>
    </select>

    <select id="selectByUser" resultMap="BaseResultMap">
        SELECT * FROM chat_message
        WHERE user_id=#{userId}
        ORDER BY create_time DESC
        <if test="limit != null">LIMIT #{limit}</if>
    </select>

    <select id="countToday" resultType="int">
        SELECT COUNT(*) FROM chat_message
        WHERE create_time BETWEEN #{startTime} AND #{endTime}
    </select>
</mapper>
