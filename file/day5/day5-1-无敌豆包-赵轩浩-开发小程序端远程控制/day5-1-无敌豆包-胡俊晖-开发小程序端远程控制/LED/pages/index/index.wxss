/* ===== 页面容器 ===== */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8edf5 0%, #f5f6fa 100%);
  padding: 0 30rpx 30rpx;
}

/* ===== 顶部欢迎区域 ===== */
.header-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: 0 -30rpx 30rpx;
  padding: 50rpx 40rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting-area {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.greeting-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.header-time {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

/* ===== 卡片通用样式 ===== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 30rpx 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.99);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-icon {
  font-size: 36rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* ===== 语音控制 ===== */
.voice-card {
  background: linear-gradient(135deg, #fff7e6 0%, #fff5f0 100%);
  border: 2rpx solid #ffdbb5;
}

.voice-btn-wrapper {
  display: flex;
  justify-content: center;
  padding: 10rpx 0;
}

.voice-btn {
  width: 80% !important;
  height: 96rpx !important;
  font-size: 32rpx !important;
  border-radius: 48rpx !important;
  background: linear-gradient(135deg, #ff9a56, #ff6b35) !important;
  border: none !important;
  box-shadow: 0 6rpx 24rpx rgba(255, 107, 53, 0.35) !important;
}

.voice-btn:active {
  transform: scale(0.96);
}

/* ===== 文字输入 ===== */
.input-card {
  background: #ffffff;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 6rpx 6rpx 6rpx 24rpx;
  border: 2rpx solid #e8ecf2;
  transition: border-color 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: #667eea;
}

.text-input {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
}

.input-placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.send-btn {
  flex-shrink: 0;
  height: 68rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.send-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.send-btn::after {
  border: none;
}

/* ===== 设备状态 ===== */
.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
}

.status-label {
  font-size: 24rpx;
  color: #999;
}

.status-value {
  font-size: 32rpx;
  font-weight: 600;
}

.status-value.online {
  color: #07c160;
}

.status-value.offline {
  color: #ee0a24;
}

.status-value.on {
  color: #ff9a56;
}

.status-value.off {
  color: #999;
}

/* ===== 灯光控制 ===== */
.control-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.control-label {
  font-size: 30rpx;
  color: #333;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin: 24rpx 0 20rpx;
}

.btn-on,
.btn-off {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  transition: all 0.2s ease;
}

.btn-on:active,
.btn-off:active {
  transform: scale(0.96);
}

.btn-on {
  background: linear-gradient(135deg, #07c160, #05a34a);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.btn-off {
  background: linear-gradient(135deg, #ee0a24, #cc0820);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(238, 10, 36, 0.3);
}

.btn-on::after,
.btn-off::after {
  border: none;
}

.light-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0 10rpx;
  cursor: pointer;
}

.light-icon {
  width: 120rpx;
  height: 120rpx;
  transition: transform 0.3s ease;
}

.light-icon:active {
  transform: scale(0.9);
}

.light-tip {
  font-size: 24rpx;
  color: #999;
}

/* ===== 环境监测 ===== */
.sensor-card {
  background: linear-gradient(135deg, #f0f8ff 0%, #e8f4fd 100%);
}

.sensor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.sensor-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 24rpx 0;
  background: rgba(255,255,255,0.6);
  border-radius: 16rpx;
}

.sensor-icon {
  font-size: 40rpx;
}

.sensor-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.sensor-label {
  font-size: 24rpx;
  color: #999;
}

/* ===== 录音弹窗 ===== */
.recording-popup {
  padding: 60rpx 80rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 30rpx;
}

.recording-icon {
  font-size: 64rpx;
}

.recording-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.recording-wave {
  display: flex;
  gap: 12rpx;
  height: 50rpx;
  align-items: flex-end;
  margin-top: 10rpx;
}

.wave-bar {
  width: 12rpx;
  background: linear-gradient(180deg, #667eea, #764ba2);
  border-radius: 6rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-bar:nth-child(1) { height: 24rpx; animation-delay: 0s; }
.wave-bar:nth-child(2) { height: 44rpx; animation-delay: 0.15s; }
.wave-bar:nth-child(3) { height: 32rpx; animation-delay: 0.3s; }
.wave-bar:nth-child(4) { height: 50rpx; animation-delay: 0.45s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1); }
}